<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glass frost background - optimized for transparency -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#990D0D0D" />
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp" />
        </shape>
    </item>
    <!-- Frosted inner highlight / Shine -->
    <item android:top="0.5dp" android:left="0.5dp" android:right="0.5dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#22FFFFFF"
                android:endColor="#00000000" />
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp" />
        </shape>
    </item>
    <!-- Top edge frost line (pronounced) -->
    <item android:bottom="-2dp" android:left="-1dp" android:right="-1dp">
        <shape android:shape="rectangle">
            <stroke android:width="1.2dp" android:color="#2AFFFFFF" />
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
